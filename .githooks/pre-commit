#!/usr/bin/env bash
# Pre-commit hook: format check + clippy lint
# Equivalent to lint-staged in the TS projects

set -e

# Ensure cargo is in PATH (Windows rustup may not add it to git-bash PATH)
export PATH="$HOME/.cargo/bin:$HOME/.rustup/toolchains/stable-x86_64-pc-windows-msvc/bin:$PATH"

echo "pre-commit: cargo fmt --check"
cargo fmt --check || {
    echo "ERROR: formatting issues found. Run 'cargo fmt' to fix."
    exit 1
}

echo "pre-commit: cargo clippy"
cargo clippy -- -D warnings || {
    echo "ERROR: clippy warnings found. Fix them before committing."
    exit 1
}
