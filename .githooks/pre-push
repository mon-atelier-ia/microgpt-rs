#!/usr/bin/env bash
# Pre-push hook: full build + tests
# Equivalent to "pnpm build && pnpm vitest run" in the TS projects

set -e

# Ensure cargo is in PATH (Windows rustup may not add it to git-bash PATH)
export PATH="$HOME/.cargo/bin:$HOME/.rustup/toolchains/stable-x86_64-pc-windows-msvc/bin:$PATH"

echo "pre-push: cargo build --release"
cargo build --release

echo "pre-push: cargo test --release"
cargo test --release
